{
  "version": 8,
  "name": "Humble Grounds Field Guide",
  "metadata": {
    "humble-grounds:notes": "Botanical field-guide map style. Paper land, celadon-wash water, ink coastlines, dashed ink borders, engraved contour relief near the destination. Matches projectcontext.md section 3 tokens.",
    "humble-grounds:journey": {
      "home": {
        "name": "Oberlin, Ohio",
        "lngLat": [
          -82.2174,
          41.293
        ]
      },
      "destinations": [
        {
          "name": "Montana de La Choca, Honduras",
          "lngLat": [
            -87.5162,
            14.5816
          ],
          "elevation_m": 1688,
          "region": "Comayagua (IHCAFE region), Parque Nacional Montana de Comayagua"
        }
      ]
    }
  },
  "center": [
    -82.2174,
    41.293
  ],
  "zoom": 3.2,
  "pitch": 0,
  "bearing": 0,
  "projection": {
    "name": "globe"
  },
  "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
  "fog": {
    "color": "#f7e7cc",
    "high-color": "#e8c878",
    "space-color": "#f2e2c4",
    "horizon-blend": 0.04,
    "star-intensity": 0
  },
  "terrain": {
    "source": "mapbox-dem",
    "exaggeration": 1.35
  },
  "sources": {
    "composite": {
      "type": "vector",
      "url": "mapbox://mapbox.mapbox-streets-v8,mapbox.mapbox-terrain-v2"
    },
    "mapbox-dem": {
      "type": "raster-dem",
      "url": "mapbox://mapbox.mapbox-terrain-dem-v1",
      "tileSize": 512,
      "maxzoom": 14
    }
  },
  "layers": [
    {
      "id": "paper",
      "type": "background",
      "paint": {
        "background-color": "#f7e7cc"
      }
    },
    {
      "id": "national-park-wash",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse_overlay",
      "minzoom": 6,
      "filter": [
        "==",
        [
          "get",
          "class"
        ],
        "national_park"
      ],
      "paint": {
        "fill-color": "#8fa07a",
        "fill-opacity": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          6,
          0.08,
          10,
          0.16
        ]
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "composite",
      "source-layer": "water",
      "paint": {
        "fill-color": "#c3d3d1"
      }
    },
    {
      "id": "coastline-ink",
      "type": "line",
      "source": "composite",
      "source-layer": "water",
      "paint": {
        "line-color": "#2b2620",
        "line-opacity": 0.8,
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          1,
          0.4,
          6,
          0.8,
          12,
          1.3
        ]
      }
    },
    {
      "id": "rivers-ink",
      "type": "line",
      "source": "composite",
      "source-layer": "waterway",
      "minzoom": 8,
      "layout": {
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#2b2620",
        "line-opacity": 0.35,
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          8,
          0.4,
          14,
          1.1
        ]
      }
    },
    {
      "id": "contours-engraved",
      "type": "line",
      "source": "composite",
      "source-layer": "contour",
      "minzoom": 9,
      "paint": {
        "line-color": "#2b2620",
        "line-opacity": [
          "case",
          [
            ">=",
            [
              "get",
              "index"
            ],
            5
          ],
          0.28,
          0.13
        ],
        "line-width": [
          "case",
          [
            ">=",
            [
              "get",
              "index"
            ],
            5
          ],
          0.8,
          0.5
        ]
      }
    },
    {
      "id": "roads-faint",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "minzoom": 11,
      "filter": [
        "match",
        [
          "get",
          "class"
        ],
        [
          "motorway",
          "trunk",
          "primary",
          "secondary",
          "tertiary",
          "street"
        ],
        true,
        false
      ],
      "paint": {
        "line-color": "#2b2620",
        "line-opacity": 0.25,
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          11,
          0.4,
          15,
          1.2
        ]
      }
    },
    {
      "id": "admin-1-dotted",
      "type": "line",
      "source": "composite",
      "source-layer": "admin",
      "minzoom": 4,
      "filter": [
        "all",
        [
          "==",
          [
            "get",
            "admin_level"
          ],
          1
        ],
        [
          "==",
          [
            "get",
            "maritime"
          ],
          "false"
        ]
      ],
      "layout": {
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#2b2620",
        "line-opacity": 0.25,
        "line-width": 0.7,
        "line-dasharray": [
          0.1,
          2.4
        ]
      }
    },
    {
      "id": "admin-0-dashed",
      "type": "line",
      "source": "composite",
      "source-layer": "admin",
      "filter": [
        "all",
        [
          "==",
          [
            "get",
            "admin_level"
          ],
          0
        ],
        [
          "==",
          [
            "get",
            "maritime"
          ],
          "false"
        ]
      ],
      "paint": {
        "line-color": "#2b2620",
        "line-opacity": 0.55,
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          2,
          0.6,
          8,
          1.1
        ],
        "line-dasharray": [
          3,
          2.2
        ]
      }
    },
    {
      "id": "ocean-labels",
      "type": "symbol",
      "source": "composite",
      "source-layer": "natural_label",
      "filter": [
        "match",
        [
          "get",
          "class"
        ],
        [
          "ocean",
          "sea"
        ],
        true,
        false
      ],
      "layout": {
        "text-field": [
          "get",
          "name_en"
        ],
        "text-font": [
          "PT Serif Italic",
          "Arial Unicode MS Regular"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          1,
          12,
          5,
          18
        ],
        "text-letter-spacing": 0.22,
        "text-max-width": 6
      },
      "paint": {
        "text-color": "#2b2620",
        "text-opacity": 0.45
      }
    },
